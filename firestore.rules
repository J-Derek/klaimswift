rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    // Members collection
    match /members/{memberId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Claims collection
    match /claims/{claimId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Conversations (bot state)
    match /conversations/{phone} {
      allow read, write: if true; // Server-side access via Admin SDK
    }

    // Blockchain events — APPEND ONLY
    match /blockchain_events/{blockId} {
      allow read: if isAdmin();
      allow create: if true; // Server creates via Admin SDK
      allow update, delete: if false; // NEVER update or delete
    }

    // M-Pesa transactions
    match /mpesa_transactions/{txId} {
      allow read: if isAdmin();
      allow write: if true; // Server-side via Admin SDK
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Claims documents
    match /claims/{claimId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if true; // Server uploads via Admin SDK
    }
  }
}
