# ============================================
# KlaimSwift — Environment Variables
# ALL variables below are MANDATORY
# ============================================

# --- Firebase ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Google Document AI ---
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# --- Safaricom Daraja API ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=
MPESA_RESULT_URL=https://yourdomain.com/webhook/mpesa/result
MPESA_TIMEOUT_URL=https://yourdomain.com/webhook/mpesa/timeout
MPESA_ENV=sandbox

# --- App ---
PORT=3000
NODE_ENV=development
ENCRYPTION_KEY=   # 32-byte hex key for AES-256 (64 hex characters)
ADMIN_JWT_SECRET=
